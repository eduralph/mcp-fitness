# Copy to ./mcp-garmin.env (gitignored) and fill in real values.

# Shared transport / logging
MCP_HOST=0.0.0.0
MCP_PORT=8080
MCP_LOG_LEVEL=INFO
MCP_TOKEN_DIR=/data/tokens

# Phase 2 — FIT-file source.
# MCP_GARMIN_FIT_DIR=/data/fit

# Phase 3 — Garmin Connect (opt-in, best-effort). Off by default.
# MCP_GARMIN_CONNECT_ENABLED=false
# MCP_GARMIN_CONNECT_EMAIL=
# MCP_GARMIN_CONNECT_PASSWORD=
