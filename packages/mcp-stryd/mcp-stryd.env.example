# Copy to ./mcp-stryd.env (gitignored) and fill in real values.

# Shared transport / logging
MCP_HOST=0.0.0.0
MCP_PORT=8080
MCP_LOG_LEVEL=INFO
MCP_TOKEN_DIR=/data/tokens

# Phase 1 — Stryd OAuth2 credentials. Leave blank until you have
# registered a developer application with Stryd.
# MCP_STRYD_CLIENT_ID=
# MCP_STRYD_CLIENT_SECRET=
# MCP_STRYD_REDIRECT_URI=https://mcp-stryd.example.net/oauth/callback
